// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Route ───────────────────────────────────────────────────
model Route {
  id              String   @id @default(uuid())
  routeId         String   @unique @map("route_id")
  shipName        String
  vesselType      String
  fuelType        String
  year            Int
  ghgIntensity    Float    @map("ghg_intensity")
  fuelConsumption Float
  distance        Float
  totalEmissions  Float
  isBaseline      Boolean  @default(false) @map("is_baseline")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  compliance ShipCompliance[]

  @@map("routes")
}

// ─── Ship Compliance ─────────────────────────────────────────
model ShipCompliance {
  id                 String   @id @default(uuid())
  shipId             String   @map("ship_id")
  shipName           String
  year               Int
  cbGco2eq           Float    @map("cb_gco2eq")
  actualGHGIntensity  Float
  targetGHGIntensity  Float
  energy             Float
  complianceBalance  Float
  status             ComplianceStatus
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  route Route @relation(fields: [shipId], references: [routeId], onDelete: Cascade)

  @@map("ship_compliance")
}

enum ComplianceStatus {
  SURPLUS
  DEFICIT
  COMPLIANT
}

// ─── Bank Entry ──────────────────────────────────────────────
model BankEntry {
  id            String        @id @default(uuid())
  shipId        String        @map("ship_id")
  shipName      String
  amount        Float         @map("amount_gco2eq")
  year          Int
  type          BankEntryType
  createdAt     DateTime      @default(now())

  @@map("bank_entries")
}

enum BankEntryType {
  BANK
  APPLY
}

// ─── Pool ────────────────────────────────────────────────────
model Pool {
  id        String       @id @default(uuid())
  name      String
  year      Int
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  members PoolMember[]

  @@map("pools")
}

// ─── Pool Member ─────────────────────────────────────────────
model PoolMember {
  id                String   @id @default(uuid())
  poolId            String   @map("pool_id")
  shipId            String   @map("ship_id")
  shipName          String
  cbBefore          Float    @map("cb_before")
  cbAfter           Float    @map("cb_after")
  contributedAmount Float    @default(0)
  createdAt         DateTime @default(now())

  pool Pool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@map("pool_members")
}

model ShipActivity {
  id         String   @id @default(uuid())
  shipId     String   @map("ship_id")
  shipName   String
  year       Int
  activity   String
  amount     Float?
  cbBefore   Float?   @map("cb_before")
  cbAfter    Float?   @map("cb_after")
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([shipId, year])
  @@index([activity])
  @@map("ship_activities")
}
